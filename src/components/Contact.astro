---
// Email is split and base64-encoded to prevent bot scraping.
// It's assembled in the browser via JS.
// "selimym.pro@gmail.com" => split into parts and encoded
const emailParts = ['c2VsaW15bS5wcm8=', 'Z21haWwuY29t']; // base64 of "selimym.pro" and "gmail.com"
---

<section id="contact" class="py-24 px-6 max-w-5xl mx-auto">
  <div class="reveal">
    <div class="flex items-center gap-3 mb-12">
      <span class="text-xs font-mono text-accent/70 uppercase tracking-widest">Contact</span>
      <div class="flex-1 h-px bg-border"></div>
    </div>
  </div>

  <div class="max-w-2xl reveal">
    <h2 class="text-3xl md:text-4xl font-bold mb-4">
      Get in touch.
    </h2>
    <p class="text-muted leading-relaxed mb-8">
      Whether you want to talk about chip design tooling, LLM systems, or just play
      <a href="https://selimym.github.io/data_privacy_dystopia/" target="_blank" rel="noopener noreferrer"
         class="text-accent hover:text-text transition-colors underline underline-offset-2">the game</a>
      and leave feedback, I'm reachable here.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 mb-12">
      <!-- Email button — rendered by JS to prevent scraping -->
      <button
        id="email-btn"
        class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-accent hover:bg-accent-dim text-bg font-semibold transition-colors text-sm"
        data-parts={JSON.stringify(emailParts)}
        onclick="handleEmailClick(this)"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        Send Email
      </button>

      <a
        href="https://www.linkedin.com/in/syahiamessaoud/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg border border-border hover:border-accent/50 text-muted hover:text-text font-medium transition-colors text-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>

      <a
        href="https://github.com/selimym"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg border border-border hover:border-accent/50 text-muted hover:text-text font-medium transition-colors text-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
    </div>
  </div>

  <!-- Footer -->
  <div class="border-t border-border pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-muted/50">
    <span>© 2025 Selim Yahia-Messaoud</span>
    <span class="font-mono">Built with Astro · Deployed on GitHub Pages</span>
  </div>
</section>

<script>
  function handleEmailClick(btn: HTMLButtonElement) {
    const parts: string[] = JSON.parse(btn.dataset.parts || '[]');
    if (parts.length === 2) {
      const user = atob(parts[0]);
      const domain = atob(parts[1]);
      window.location.href = `mailto:${user}@${domain}`;
    }
  }
  (window as any).handleEmailClick = handleEmailClick;
</script>
