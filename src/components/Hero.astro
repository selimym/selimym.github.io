---
---

<section id="hero" class="relative min-h-screen flex flex-col justify-center px-6 md:px-12 overflow-hidden">

  <!-- Background glow -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/2 left-1/3 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-accent/6 rounded-full blur-[140px]"></div>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto w-full grid md:grid-cols-2 gap-12 items-center pt-20">

    <!-- Left: Text -->
    <div>
      <h1 class="text-5xl md:text-6xl font-bold tracking-tight leading-[1.05] mb-5">
        Selim<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent via-yellow-300 to-amber-600">Yahia-Messaoud</span>
      </h1>

      <p class="text-base text-muted font-mono mb-6 tracking-wide">
        Senior Software Engineer
      </p>

      <p class="text-base text-muted/80 leading-relaxed mb-10 max-w-md">
        At Qualcomm I write Python tools for chip designers. My code sits in the critical path for silicon
        that ends up in hundreds of millions of phones. On the side: LLM systems and
        <a href="https://selimym.github.io/data_privacy_distopia/" target="_blank" rel="noopener noreferrer"
           class="text-accent hover:text-text transition-colors underline underline-offset-2">one browser game</a>
        about surveillance ethics.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-3 mb-10">
        <a
          href="#projects"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-accent hover:bg-accent-dim text-bg font-semibold transition-colors text-sm"
        >
          View Projects
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="#contact"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-border hover:border-accent/50 text-muted hover:text-text font-medium transition-colors text-sm"
        >
          Get in touch
        </a>
      </div>

      <!-- Social links -->
      <div class="flex items-center gap-5">
        <a href="https://github.com/selimym" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
        <a href="https://www.linkedin.com/in/syahiamessaoud/" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <a href="#contact" class="social-link" aria-label="Email">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Email
        </a>
      </div>
    </div>

    <!-- Right: IC chip illustration -->
    <div class="hidden md:flex justify-center items-center">
      <svg
        viewBox="-8 -8 256 256"
        class="w-[340px] h-[340px] text-accent opacity-[0.14]"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <!-- Outer package with pin-1 chamfer at top-left -->
        <path d="M28 10 L230 10 L230 230 L10 230 L10 28 Z" stroke="currentColor" stroke-width="1.5"/>

        <!-- Pin 1 marker dot -->
        <circle cx="19" cy="19" r="3" fill="currentColor" opacity="0.9"/>

        <!-- Die boundary -->
        <rect x="68" y="68" width="104" height="104" stroke="currentColor" stroke-width="1.2"/>

        <!-- Die internal grid -->
        <line x1="86" y1="68" x2="86" y2="172" stroke="currentColor" stroke-width="0.3" opacity="0.6"/>
        <line x1="104" y1="68" x2="104" y2="172" stroke="currentColor" stroke-width="0.3" opacity="0.6"/>
        <line x1="120" y1="68" x2="120" y2="172" stroke="currentColor" stroke-width="0.3" opacity="0.6"/>
        <line x1="136" y1="68" x2="136" y2="172" stroke="currentColor" stroke-width="0.3" opacity="0.6"/>
        <line x1="154" y1="68" x2="154" y2="172" stroke="currentColor" stroke-width="0.3" opacity="0.6"/>

        <line x1="68" y1="86" x2="172" y2="86" stroke="currentColor" stroke-width="0.3" opacity="0.6"/>
        <line x1="68" y1="104" x2="172" y2="104" stroke="currentColor" stroke-width="0.3" opacity="0.6"/>
        <line x1="68" y1="120" x2="172" y2="120" stroke="currentColor" stroke-width="0.3" opacity="0.6"/>
        <line x1="68" y1="136" x2="172" y2="136" stroke="currentColor" stroke-width="0.3" opacity="0.6"/>
        <line x1="68" y1="154" x2="172" y2="154" stroke="currentColor" stroke-width="0.3" opacity="0.6"/>

        <!-- Leads — top (3 leads at x=88, 120, 152) -->
        <line x1="88" y1="68" x2="88" y2="10" stroke="currentColor" stroke-width="0.9"/>
        <line x1="120" y1="68" x2="120" y2="10" stroke="currentColor" stroke-width="0.9"/>
        <line x1="152" y1="68" x2="152" y2="10" stroke="currentColor" stroke-width="0.9"/>
        <rect x="84" y="6" width="8" height="6" fill="currentColor" opacity="0.8"/>
        <rect x="116" y="6" width="8" height="6" fill="currentColor" opacity="0.8"/>
        <rect x="148" y="6" width="8" height="6" fill="currentColor" opacity="0.8"/>

        <!-- Leads — bottom -->
        <line x1="88" y1="172" x2="88" y2="230" stroke="currentColor" stroke-width="0.9"/>
        <line x1="120" y1="172" x2="120" y2="230" stroke="currentColor" stroke-width="0.9"/>
        <line x1="152" y1="172" x2="152" y2="230" stroke="currentColor" stroke-width="0.9"/>
        <rect x="84" y="228" width="8" height="6" fill="currentColor" opacity="0.8"/>
        <rect x="116" y="228" width="8" height="6" fill="currentColor" opacity="0.8"/>
        <rect x="148" y="228" width="8" height="6" fill="currentColor" opacity="0.8"/>

        <!-- Leads — left -->
        <line x1="68" y1="88" x2="10" y2="88" stroke="currentColor" stroke-width="0.9"/>
        <line x1="68" y1="120" x2="10" y2="120" stroke="currentColor" stroke-width="0.9"/>
        <line x1="68" y1="152" x2="10" y2="152" stroke="currentColor" stroke-width="0.9"/>
        <rect x="6" y="84" width="6" height="8" fill="currentColor" opacity="0.8"/>
        <rect x="6" y="116" width="6" height="8" fill="currentColor" opacity="0.8"/>
        <rect x="6" y="148" width="6" height="8" fill="currentColor" opacity="0.8"/>

        <!-- Leads — right -->
        <line x1="172" y1="88" x2="230" y2="88" stroke="currentColor" stroke-width="0.9"/>
        <line x1="172" y1="120" x2="230" y2="120" stroke="currentColor" stroke-width="0.9"/>
        <line x1="172" y1="152" x2="230" y2="152" stroke="currentColor" stroke-width="0.9"/>
        <rect x="228" y="84" width="6" height="8" fill="currentColor" opacity="0.8"/>
        <rect x="228" y="116" width="6" height="8" fill="currentColor" opacity="0.8"/>
        <rect x="228" y="148" width="6" height="8" fill="currentColor" opacity="0.8"/>

        <!-- Corner fiducials -->
        <polyline points="10,22 10,10 22,10" stroke="currentColor" stroke-width="0.8" opacity="0.4"/>
        <polyline points="218,10 230,10 230,22" stroke="currentColor" stroke-width="0.8" opacity="0.4"/>
        <polyline points="10,218 10,230 22,230" stroke="currentColor" stroke-width="0.8" opacity="0.4"/>
        <polyline points="218,230 230,230 230,218" stroke="currentColor" stroke-width="0.8" opacity="0.4"/>
      </svg>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-6 md:left-12 flex items-center gap-2 text-muted/40">
    <div class="w-px h-10 bg-gradient-to-b from-transparent to-muted/30"></div>
    <span class="text-xs font-mono rotate-0">scroll</span>
  </div>
</section>

<style>
  .social-link {
    @apply flex items-center gap-2 text-sm text-muted hover:text-text transition-colors;
  }
</style>
