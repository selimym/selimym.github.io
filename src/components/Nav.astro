---
---

<header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 md:px-12 h-14 bg-bg/80 backdrop-blur-md border-b border-border/50">
  <a href="#hero" class="font-mono text-sm text-muted hover:text-text transition-colors">
    selimym<span class="text-accent">.pro</span>
  </a>

  <nav class="hidden md:flex items-center gap-8">
    <a href="#about" class="nav-link">About</a>
    <a href="#experience" class="nav-link">Experience</a>
    <a href="#projects" class="nav-link">Projects</a>
    <a href="#skills" class="nav-link">Skills</a>
    <a href="#contact" class="nav-link">Contact</a>
  </nav>

  <a
    href="#contact"
    class="hidden md:inline-flex items-center gap-2 text-sm font-medium px-4 py-1.5 rounded-md border border-accent/40 text-accent hover:bg-accent/10 transition-colors"
  >
    Contact
  </a>

  <!-- Mobile menu button -->
  <button id="mobile-menu-toggle" class="md:hidden text-muted hover:text-text transition-colors" aria-label="Toggle menu">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  </button>
</header>

<!-- Mobile nav -->
<div id="mobile-nav" class="fixed top-14 left-0 right-0 z-40 bg-bg/95 backdrop-blur-md border-b border-border hidden">
  <nav class="flex flex-col px-6 py-4 gap-4">
    <a href="#about" class="nav-link" onclick="closeMobileNav()">About</a>
    <a href="#experience" class="nav-link" onclick="closeMobileNav()">Experience</a>
    <a href="#projects" class="nav-link" onclick="closeMobileNav()">Projects</a>
    <a href="#skills" class="nav-link" onclick="closeMobileNav()">Skills</a>
    <a href="#contact" class="nav-link" onclick="closeMobileNav()">Contact</a>
  </nav>
</div>

<style>
  .nav-link {
    @apply text-sm text-muted hover:text-text transition-colors;
  }
</style>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const nav = document.getElementById('mobile-nav');

  toggle?.addEventListener('click', () => {
    nav?.classList.toggle('hidden');
  });

  function closeMobileNav() {
    nav?.classList.add('hidden');
  }
  (window as any).closeMobileNav = closeMobileNav;
</script>
